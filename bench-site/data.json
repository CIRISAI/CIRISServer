    "capacity_scoring": {
      "metric": "capacity:sustained_coherence:v1",
      "algorithm": "n_eff_pr (participation ratio of the lens constraint eigenspectrum)",
      "description": "Node A derives per-agent n_eff from ingested traces \u2192 n_eff_pr \u2192 capacity(n_eff_pr, gate=20, target=8) \u2192 [0,1] score \u2192 emits capacity:sustained_coherence:v1 attestation (hybrid-signed CEG scores row).",
      "live_observations": {
        "node_a_emits": true,
        "node_b_receives_via_replication": true,
        "replication_protocol": "consent:replication:v1, mutual key-reg, each node owns its corpus",
        "note": "The live capacity score value depends on the corpus (agent traces ingested). With a thin corpus (<20 traces) the gate returns 0.0 honestly. With a corpus meeting the gate the score is in [0,1]. The gate semantics are: emit 0.0 rather than skip \u2014 a zero-row is 'observed but not yet scored', not 'missing'."
      }
    },
